# Ensure shell scripts always use LF line endings in the repository.
# Without this, editing on Windows produces CRLF which breaks bash -n checks.

* text=auto

*.sh text eol=lf
*.py text eol=lf
*.md text eol=lf
*.env text eol=lf
*.service text eol=lf
*.json text eol=lf
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binary files
*.tar.gz binary
*.gz binary
*.zip binary
*.png binary
*.jpg binary
*.ico binary
